    # ── Gauge animée ─────────────────────────
    class GaugeMeter(tk.Canvas):
        MAX_PRICE = 200_000

        def __init__(self, parent, **kw):
            super().__init__(parent,
                             bg=_C["BG2"], highlightthickness=0,
                             width=300, height=170, **kw)
            self._target  = 0.0
            self._current = 0.0
            self._anim_id = None
            self._draw_static()
            self._arc_id   = None
            self._needle_id = None
            self._price_id = self.create_text(
                150, 100, text="—",
                font=("Segoe UI", 26, "bold"),
                fill=_C["TEXT"], anchor="center"
            )
            self._sub_id = self.create_text(
                150, 126, text="estimation (meilleur modèle)",
                font=("Segoe UI", 8),
                fill=_C["TEXT2"], anchor="center"
            )

        def _draw_static(self):
            # Arc de fond
            self.create_arc(20, 14, 280, 194,
                            start=180, extent=180,
                            style="arc", outline=_C["BG3"], width=16)
            # Ticks
            cx, cy, r = 150, 150, 115
            for i in range(11):
                a  = math.radians(180 - i * 18)
                x1 = cx + (r - 10) * math.cos(a)
                y1 = cy - (r - 10) * math.sin(a)
                x2 = cx + r * math.cos(a)
                y2 = cy - r * math.sin(a)
                self.create_line(x1, y1, x2, y2,
                                 fill=_C["BORDER"], width=2)

        def set_value(self, price: float):
            self._target = min(max(price, 0), self.MAX_PRICE)
            if self._anim_id:
                self.after_cancel(self._anim_id)
            self._animate()

        def _animate(self):
            diff = self._target - self._current
            step = diff * 0.16
            if abs(diff) < 80:
                self._current = self._target
            else:
                self._current += step

            ratio  = self._current / self.MAX_PRICE
            extent = ratio * 180

            # Arc coloré
            self.delete("arc_fill")
            if extent > 1:
                # Vert→ambre→rouge selon ratio
                if ratio < 0.5:
                    r_c = int(80  + 160 * ratio * 2)
                    g_c = int(200 - 40  * ratio * 2)
                    b_c = 100
                else:
                    r_c = 240
                    g_c = int(160 - 120 * (ratio - 0.5) * 2)
                    b_c = 50
                col = f"#{min(r_c,255):02x}{min(g_c,255):02x}{min(b_c,255):02x}"
                self.create_arc(20, 14, 280, 194,
                                start=180, extent=extent,
                                style="arc", outline=col, width=16,
                                tags="arc_fill")

            # Aiguille
            self.delete("needle")
            a  = math.radians(180 - ratio * 180)
            cx, cy = 150, 150
            nx = cx + 100 * math.cos(a)
            ny = cy - 100 * math.sin(a)
            self.create_line(cx, cy, nx, ny,
                             fill=_C["ACCENT"], width=3,
                             capstyle="round", tags="needle")
            self.create_oval(cx - 5, cy - 5, cx + 5, cy + 5,
                             fill=_C["ACCENT"], outline="",
                             tags="needle")

            # Texte
            self.itemconfigure(self._price_id,
                               text=f"${self._current:,.0f}")

            if abs(self._current - self._target) > 40:
                self._anim_id = self.after(28, self._animate)
            else:
                self._anim_id = None

    # ── Champ de formulaire ──────────────────
    class FormField(tk.Frame):
        def __init__(self, parent, label, var,
                     widget="entry", choices=None, **kw):
            super().__init__(parent, bg=_C["BG2"], **kw)

            tk.Label(self, text=label,
                     font=("Segoe UI", 9), fg=_C["TEXT2"],
                     bg=_C["BG2"], anchor="w", width=24
                     ).pack(side="left", padx=(0, 6))

            if widget == "combo" and choices:
                cb = ttk.Combobox(self, textvariable=var,
                                  values=choices, state="readonly",
                                  width=22)
                cb.pack(side="left", fill="x", expand=True)
                if choices and not var.get():
                    var.set(choices[0])
            else:
                ent = tk.Entry(self, textvariable=var,
                               bg=_C["BG3"], fg=_C["TEXT"],
                               insertbackground=_C["ACCENT"],
                               relief="flat", font=("Segoe UI", 10),
                               highlightthickness=1,
                               highlightbackground=_C["BORDER"],
                               highlightcolor=_C["ACCENT"],
                               width=24)
                ent.pack(side="left", fill="x", expand=True)

    # ── Fenêtre principale ───────────────────
