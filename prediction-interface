            self._results = {}

            self._build_header()
            self._build_body()
            self._build_statusbar()

        # ── En-tête ──────────────────────────
        def _build_header(self):
            hdr = tk.Frame(self, bg=_C["BG"], pady=10)
            hdr.pack(fill="x", padx=20)

            tk.Label(hdr, text="AUTO",
                     font=("Segoe UI", 18, "bold"),
                     fg=_C["ACCENT"], bg=_C["BG"]).pack(side="left")
            tk.Label(hdr, text="PREDICT",
                     font=("Segoe UI", 18),
                     fg=_C["TEXT"], bg=_C["BG"]).pack(side="left")

            info = (f"  ·  entraîné le {meta['trained_at'][:10]}"
                    f"  ·  {meta['sample_size']:,} véhicules"
                    f"  ·  meilleur : {BEST_MODEL}"
                    f"  (R²={RESULTS[BEST_MODEL]['R2']:.3f})")
            tk.Label(hdr, text=info,
                     font=("Segoe UI", 8),
                     fg=_C["TEXT2"], bg=_C["BG"]).pack(side="left", padx=8)

            tk.Frame(self, bg=_C["BORDER"], height=1).pack(fill="x")

        # ── Corps (formulaire gauche + résultats droite) ──
        def _build_body(self):
            body = tk.Frame(self, bg=_C["BG"])
            body.pack(fill="both", expand=True)

            left = tk.Frame(body, bg=_C["BG2"], width=420)
            left.pack(side="left", fill="y")
            left.pack_propagate(False)

            tk.Frame(body, bg=_C["BORDER"], width=1).pack(side="left", fill="y")

            right = tk.Frame(body, bg=_C["BG"])
            right.pack(side="left", fill="both", expand=True)

            self._build_form(left)
            self._build_results(right)

        # ── Formulaire ───────────────────────
        def _build_form(self, parent):
            # Canvas + scrollbar
            canvas = tk.Canvas(parent, bg=_C["BG2"],
                               highlightthickness=0)
            sb     = ttk.Scrollbar(parent, orient="vertical",
                                   command=canvas.yview)
            frm    = tk.Frame(canvas, bg=_C["BG2"])

            frm.bind("<Configure>",
                     lambda e: canvas.configure(
                         scrollregion=canvas.bbox("all")))
            canvas.create_window((0, 0), window=frm, anchor="nw")
            canvas.configure(yscrollcommand=sb.set)
            canvas.pack(side="left", fill="both", expand=True)
            sb.pack(side="right", fill="y")

            def _scroll(e):
                canvas.yview_scroll(int(-1 * (e.delta / 120)), "units")
            canvas.bind_all("<MouseWheel>", _scroll)

            def section(title):
                tk.Label(frm, text=title.upper(),
                         font=("Segoe UI", 7, "bold"),
                         fg=_C["ACCENT"], bg=_C["BG2"],
                         anchor="w").pack(
                    fill="x", padx=16, pady=(14, 2))
                tk.Frame(frm, bg=_C["BORDER"],
                         height=1).pack(fill="x", padx=16, pady=(0, 6))

            def field(label, key, widget="entry", choices=None,
                      default=None):
                var = (tk.StringVar(value=str(default) if default is not None else "")
                       if widget in ("entry", "combo")
                       else tk.StringVar())
                self._vars[key] = var
                ff = FormField(frm, label, var,
                               widget=widget, choices=choices)
                ff.pack(fill="x", padx=16, pady=3)
                if default is not None and isinstance(var, tk.StringVar):
                    var.set(str(default))
                return var

            # ── Section 1 ──
            section("Caractéristiques générales")
            field("Année de fabrication",   "year",      default=CURRENT_YEAR - 3)
            field("Kilométrage (km)",        "mileage",   default=50000)
            if "engine_hp" in NUM_FEATURES:
                field("Puissance moteur (ch)", "engine_hp", default=150)
            field("Nb de propriétaires",    "owner_count",      default=1)
            field("Popularité marque (0–100)", "brand_popularity", default=60)

            # ── Section 2 ──
            section("Identification du véhicule")
            field("Marque",       "make",         "combo",
                  CAT_VALUES.get("make", ["Toyota"]))
            field("Carrosserie",  "body_type",    "combo",
                  CAT_VALUES.get("body_type", ["Sedan"]))
            field("Carburant",    "fuel_type",    "combo",
                  CAT_VALUES.get("fuel_type", ["Gasoline"]))
            field("Traction",     "drivetrain",   "combo",
                  CAT_VALUES.get("drivetrain", ["FWD"]))
            field("Transmission", "transmission", "combo",
                  CAT_VALUES.get("transmission", ["Automatic"]))

            # ── Section 3 ──
            section("Historique & état")
            field("Accidents",    "accident_history", "combo",
                  CAT_VALUES.get("accident_history", ["No", "Yes"]))
            field("Type vendeur", "seller_type",      "combo",
                  CAT_VALUES.get("seller_type", ["Dealer"]))
            if ORD_FEATURES:
                field("Condition", "condition", "combo",
                      CAT_VALUES.get("condition",
                                     ["Poor", "Fair", "Good", "Excellent"]))

            # ── Section 4 ──
            section("Couleurs")
            field("Couleur extérieure", "exterior_color", "combo",
                  CAT_VALUES.get("exterior_color", ["White"]))
            field("Couleur intérieure", "interior_color", "combo",
                  CAT_VALUES.get("interior_color", ["Black"]))

            # ── Sélecteur modèle + bouton ──
            tk.Frame(frm, bg=_C["BORDER"], height=1).pack(
                fill="x", padx=16, pady=(14, 0))

            ctrl = tk.Frame(frm, bg=_C["BG2"])
            ctrl.pack(fill="x", padx=16, pady=10)

            self._model_var = tk.StringVar(value=BEST_MODEL)
            model_opts      = AVAILABLE_MODELS + ["— Tous —"]
            ttk.Combobox(ctrl, textvariable=self._model_var,
                         values=model_opts, state="readonly",
                         width=17).pack(side="left", padx=(0, 8))

            ttk.Button(ctrl, text="  Estimer le prix  ",
                       style="Accent.TButton",
                       command=self._on_predict
                       ).pack(side="left", fill="x", expand=True)

            # Batch CSV
            ttk.Button(frm, text="⬆  Importer CSV (batch)",
                       style="Ghost.TButton",
                       command=self._on_batch
                       ).pack(padx=16, pady=(0, 16), anchor="w")

        # ── Résultats ────────────────────────
        def _build_results(self, parent):
            rhead = tk.Frame(parent, bg=_C["BG"], pady=8)
            rhead.pack(fill="x", padx=24)
            tk.Label(rhead, text="Résultats",
                     font=("Segoe UI", 14, "bold"),
                     fg=_C["TEXT"], bg=_C["BG"]).pack(side="left")

            # Gauge
            gf = tk.Frame(parent, bg=_C["BG"])
            gf.pack(pady=4)
            self._gauge = GaugeMeter(gf)
            self._gauge.pack()
            self._gauge_sub = tk.Label(
                gf,
                text=f"Meilleur modèle : {BEST_MODEL}",
                font=("Segoe UI", 8), fg=_C["TEXT2"], bg=_C["BG"]
            )
            self._gauge_sub.pack()

            # Séparateur
            tk.Frame(parent, bg=_C["BORDER"], height=1).pack(
                fill="x", padx=24, pady=(8, 4))

            # En-tête tableau
            thead = tk.Frame(parent, bg=_C["BG"])
            thead.pack(fill="x", padx=24)
            for txt, w, anchor in [
                ("Modèle",        20, "w"),
                ("Prix estimé",   14, "e"),
                ("R²",             6, "e"),
                ("MAE",           10, "e"),
            ]:
                tk.Label(thead, text=txt,
                         font=("Segoe UI", 8, "bold"),
                         fg=_C["TEXT2"], bg=_C["BG"],
                         width=w, anchor=anchor
                         ).pack(side="left")

            tk.Frame(parent, bg=_C["BORDER"], height=1).pack(
                fill="x", padx=24, pady=(2, 4))

            # Corps tableau (remplacé à chaque prédiction)
            self._table = tk.Frame(parent, bg=_C["BG"])
            self._table.pack(fill="both", expand=True, padx=24)

            # Log
            tk.Frame(parent, bg=_C["BORDER"], height=1).pack(
                fill="x", padx=24, pady=(6, 2))
            self._log = tk.Text(
                parent, height=5, bg=_C["BG2"], fg=_C["TEXT2"],
                font=("Consolas", 9), relief="flat",
                state="disabled", padx=8, pady=6,
                insertbackground=_C["TEXT"]
            )
            self._log.pack(fill="x", padx=24, pady=(0, 10))
            self._log_write("Prêt — saisissez les caractéristiques"
                            " et cliquez sur « Estimer le prix ».")

        # ── Barre de statut ──────────────────
        def _build_statusbar(self):
            sb = tk.Frame(self, bg=_C["BG3"], height=22)
            sb.pack(fill="x", side="bottom")
            tk.Frame(sb, bg=_C["BORDER"], height=1).pack(fill="x")
            self._status = tk.StringVar(
                value=f"Modèles dans : {MODELS_DIR}  ·  "
                      f"entraîné le {meta['trained_at'][:10]}"
            )
            tk.Label(sb, textvariable=self._status,
                     font=("Segoe UI", 8), fg=_C["TEXT2"],
                     bg=_C["BG3"], anchor="w", padx=8
                     ).pack(side="left", fill="x")

        # ── Helpers ──────────────────────────
        def _log_write(self, msg: str):
            self._log.configure(state="normal")
            ts = datetime.now().strftime("%H:%M:%S")
            self._log.insert("end", f"[{ts}]  {msg}\n")
            self._log.see("end")
            self._log.configure(state="disabled")

        def _status_set(self, msg: str):
            self._status.set(msg)

        def _get_var(self, key: str, fallback=""):
            v = self._vars.get(key)
            if v is None:
                return fallback
            return v.get()

        def _collect_row(self) -> dict:
            try:
                year      = int(self._get_var("year", CURRENT_YEAR - 3))
                mileage   = float(self._get_var("mileage", 50000))
                engine_hp = (float(self._get_var("engine_hp", 150))
                             if "engine_hp" in self._vars else 150.0)
                owner_cnt = int(self._get_var("owner_count", 1))
                brand_pop = float(self._get_var("brand_popularity", 60))
            except ValueError as e:
                raise ValueError(f"Champ numérique invalide : {e}") from e

            return collect_row_from_values(
                year, mileage, engine_hp, owner_cnt, brand_pop,
                self._get_var("make",             "Toyota"),
                self._get_var("fuel_type",        "Gasoline"),
                self._get_var("drivetrain",       "FWD"),
                self._get_var("body_type",        "Sedan"),
                self._get_var("transmission",     "Automatic"),
                self._get_var("exterior_color",   "White"),
                self._get_var("interior_color",   "Black"),
                self._get_var("seller_type",      "Dealer"),
                self._get_var("accident_history", "No"),
                self._get_var("condition",        "Good"),
            )

        # ── Prédiction ───────────────────────
        def _on_predict(self):
            try:
                row_dict = self._collect_row()
            except ValueError as e:
                messagebox.showerror("Erreur de saisie", str(e))
                return

            sel   = self._model_var.get()
            names = (AVAILABLE_MODELS if sel == "— Tous —"
                     else [sel])
            self._log_write(f"Prédiction → {', '.join(names)} …")
            self._status_set("Calcul en cours…")

            def worker():
                results = {}
                input_df = build_input_df(row_dict)
                for name in names:
                    try:
                        pipe  = load_model(name)
                        price = predict_price(pipe, input_df.copy())[0]
                        results[name] = price
                    except Exception as ex:
                        results[name] = None
                        self.after(0, self._log_write,
                                   f"  ✗ {name} : {ex}")
                self.after(0, self._show_results, results)

            threading.Thread(target=worker, daemon=True).start()

        def _show_results(self, results: dict):
            # Vider tableau
            for w in self._table.winfo_children():
                w.destroy()

            best_price = None

            for name, price in results.items():
                r       = RESULTS[name]
                is_best = (name == BEST_MODEL)
                row_bg  = _C["BG4"] if is_best else _C["BG"]

                row_f = tk.Frame(self._table, bg=row_bg)
                row_f.pack(fill="x", pady=1)

                prefix = "★ " if is_best else "  "
                tk.Label(row_f,
                         text=f"{prefix}{name}",
                         font=("Segoe UI", 9,
                               "bold" if is_best else "normal"),
                         fg=_C["ACCENT"] if is_best else _C["TEXT"],
                         bg=row_bg, width=20, anchor="w"
                         ).pack(side="left", padx=(4, 0))

                price_txt = (f"${price:>12,.0f}"
                             if price is not None else "     erreur")
                price_fg  = (_C["SUCCESS"] if price is not None
                             else _C["DANGER"])
                tk.Label(row_f, text=price_txt,
                         font=("Consolas", 10, "bold"),
                         fg=price_fg, bg=row_bg,
                         width=14, anchor="e"
                         ).pack(side="left")

                tk.Label(row_f, text=f"{r['R2']:.3f}",
                         font=("Consolas", 9),
                         fg=_C["TEXT2"], bg=row_bg,
                         width=6, anchor="e"
                         ).pack(side="left")

                tk.Label(row_f, text=f"${r['MAE']:>9,.0f}",
                         font=("Consolas", 9),
                         fg=_C["TEXT2"], bg=row_bg,
                         width=10, anchor="e"
                         ).pack(side="left")

                if is_best and price is not None:
                    best_price = price

            if best_price is not None:
                self._gauge.set_value(best_price)
                self._log_write(
                    f"  ✓ Estimation (meilleur modèle) : "
                    f"${best_price:,.0f}")
                self._status_set(
                    f"Dernière estimation : ${best_price:,.0f}"
                    f" via {BEST_MODEL}")
            else:
                self._status_set("Prédiction terminée.")

            self._results = results

        # ── Batch CSV ────────────────────────
        def _on_batch(self):
            path = filedialog.askopenfilename(
                title="Choisir un fichier CSV",
                filetypes=[("CSV", "*.csv"), ("Tous", "*.*")]
            )
            if not path:
                return

            csv_path = Path(path)
            self._log_write(f"Batch : {csv_path.name}")
            self._status_set("Batch en cours…")

            def worker():
                try:
                    df = pd.read_csv(csv_path)
                    df.columns = df.columns.str.strip().str.lower()
                    self.after(0, self._log_write,
                               f"  {len(df):,} lignes chargées")

                    out = df.copy()
                    for name in AVAILABLE_MODELS:
                        pipe  = load_model(name)
                        preds = predict_price(pipe, df.copy())
                        out[f"predicted_price_{name}"] = preds.round(2)
                        med = float(np.median(preds))
                        self.after(0, self._log_write,
                                   f"  {name} → médiane ${med:,.0f}")

                    ts    = datetime.now().strftime("%Y%m%d_%H%M%S")
                    outp  = csv_path.parent / f"predictions_output_{ts}.csv"
                    out.to_csv(outp, index=False)
                    self.after(0, self._log_write,
                               f"  ✓ Exporté : {outp.name}")
                    self.after(0, self._status_set,
                               f"Batch terminé → {outp.name}")
                    self.after(0, messagebox.showinfo,
                               "Batch terminé",
                               f"Résultats exportés :\n{outp}")
                except Exception as ex:
                    self.after(0, self._log_write,
                               f"  ✗ Erreur batch : {ex}")
                    self.after(0, self._status_set,
                               "Batch : erreur.")

            threading.Thread(target=worker, daemon=True).start()

    app = PredictApp()
    app.mainloop()


