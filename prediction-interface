def safe_div(a: float, b: float, fallback: float = 1.0) -> float:
    """Division sûre — évite ZeroDivisionError quand b == 0."""
    return a / b if b != 0 else fallback


def select_model_names() -> list[str]:
    """
    FIX BUG 2 & 5 — centralise la sélection des modèles.
    Priorité : --model  >  --all  >  BEST_MODEL uniquement.
    """
    if args.model:
        if args.model not in AVAILABLE_MODELS:
            print(f"\nERREUR : modèle '{args.model}' inconnu.")
            print(f"  Disponibles : {AVAILABLE_MODELS}")
            sys.exit(1)
        return [args.model]
    if args.all:
        return list(AVAILABLE_MODELS)
    return [BEST_MODEL]


def load_model(name: str):
    """Charge un pipeline joblib depuis le dossier models/."""
    path = MODELS_DIR / f"{name}.joblib"
    if not path.exists():
        print(f"\nERREUR : {path} introuvable. Relancez train.py.")
        sys.exit(1)
    return joblib.load(path)


def apply_feature_engineering(data: pd.DataFrame) -> pd.DataFrame:
    """
    FIX BUG 3 — feature engineering robuste avec safe_div().
    Ajoute car_age, mileage_per_year, hp_per_year si absents.
    """
    if "year" not in data.columns or "car_age" in data.columns:
        return data          # déjà calculé ou impossible

    data = data.copy()
    data["car_age"] = (CURRENT_YEAR - data["year"]).clip(lower=0)

    # safe_div vectorisé via np.where
    age_safe = np.where(data["car_age"] == 0, 1, data["car_age"])

    if "mileage" in data.columns:
        data["mileage_per_year"] = data["mileage"] / age_safe

    if "engine_hp" in data.columns:
        data["hp_per_year"] = data["engine_hp"] / age_safe

    return data


def predict_price(pipe, data: pd.DataFrame) -> np.ndarray:
    """
    Prédit les prix à partir d'un DataFrame.
    Retourne un array de prix en $ (toujours ≥ 0).
    """
    data = apply_feature_engineering(data)

    # Aligner exactement les colonnes de l'entraînement
    for col in ALL_FEATURES:
        if col not in data.columns:
            data[col] = np.nan
    data = data[ALL_FEATURES]

    y_log  = pipe.predict(data)
    y_orig = np.clip(np.expm1(y_log), a_min=0, a_max=None)
    return y_orig


def build_input_df(row_dict: dict) -> pd.DataFrame:
    """Construit un DataFrame d'une ligne aligné sur ALL_FEATURES."""
    row = {k: v for k, v in row_dict.items() if k in ALL_FEATURES}
    # Colonnes manquantes → NaN
    for col in ALL_FEATURES:
        if col not in row:
            row[col] = np.nan
    return pd.DataFrame([row])[ALL_FEATURES]


def collect_row_from_values(
    year, mileage, engine_hp, owner_count, brand_popularity,
    make, fuel_type, drivetrain, body_type, transmission,
    exterior_color, interior_color, seller_type, accident_history,
    condition
) -> dict:
    """Construit le dict de features à partir de valeurs brutes."""
    car_age          = max(CURRENT_YEAR - int(year), 0)
    mileage_per_year = safe_div(float(mileage), max(car_age, 1))
    hp_per_year      = safe_div(float(engine_hp), max(car_age, 1))

    return dict(
        year             = int(year),
        mileage          = float(mileage),
        engine_hp        = float(engine_hp),
        owner_count      = int(owner_count),
        brand_popularity = float(brand_popularity),
        car_age          = car_age,
        mileage_per_year = mileage_per_year,
        hp_per_year      = hp_per_year,
        make             = str(make),
        fuel_type        = str(fuel_type),
        drivetrain       = str(drivetrain),
        body_type        = str(body_type),
        transmission     = str(transmission),
        exterior_color   = str(exterior_color),
        interior_color   = str(interior_color),
        seller_type      = str(seller_type),
        accident_history = str(accident_history),
        condition        = str(condition),
    )


# ─────────────────────────────────────────────
# 3A. MODE BATCH (--csv)
# ─────────────────────────────────────────────
if args.csv:
    csv_path = Path(args.csv)
    if not csv_path.exists():
        print(f"\nERREUR : fichier introuvable : {csv_path}")
        sys.exit(1)

    print(f"\n{'─'*50}")
    print(f"Mode batch : {csv_path}")
    batch_df = pd.read_csv(csv_path)
    batch_df.columns = batch_df.columns.str.strip().str.lower()
    print(f"  {len(batch_df):,} lignes chargées")

    model_names = select_model_names()   # FIX BUG 2 & 5
    output_df   = batch_df.copy()

    for name in model_names:
        print(f"\n  Prédiction avec {name}...")
        pipe  = load_model(name)
        preds = predict_price(pipe, batch_df.copy())
        output_df[f"predicted_price_{name}"] = preds.round(2)
        print(
            f"    Min : ${preds.min():,.0f}  |  "
            f"Médiane : ${np.median(preds):,.0f}  |  "
            f"Max : ${preds.max():,.0f}"
        )

    ts       = datetime.now().strftime("%Y%m%d_%H%M%S")
    out_path = csv_path.parent / f"predictions_output_{ts}.csv"
    output_df.to_csv(out_path, index=False)
    print(f"\n  Résultats exportés : {out_path}")
    sys.exit(0)


